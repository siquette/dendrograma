# ============================================
# NEXAS Analytics — Variáveis de Ambiente
# ============================================

# Conexão com o Banco de Dados
# Para produção (PostgreSQL): postgresql://usuario:senha@localhost:5432/nexas
# Para desenvolvimento local (SQLite): sqlite:///./nexas.db
DATABASE_URL=sqlite:///./nexas.db

# Configuração da aplicação
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0

# CORS
CORS_ORIGINS=http://localhost:8000,http://localhost:3000