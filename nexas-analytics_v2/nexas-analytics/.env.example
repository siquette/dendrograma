# ============================================
# NEXAS Analytics — Variáveis de Ambiente
# Copie para .env e preencha com valores reais:
#   copy .env.example .env
# ============================================

# Conexão com o banco de dados
# SQLite (desenvolvimento — zero instalação):
DATABASE_URL=sqlite:///dados/nexas.db

# PostgreSQL (produção — descomentar quando migrar):
# DATABASE_URL=postgresql://nexas:sua_senha_aqui@localhost:5432/nexas

# Configuração da aplicação
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0

# CORS — domínios permitidos no frontend (separados por vírgula)
CORS_ORIGINS=http://localhost:8000,http://localhost:3000
